# API Configurations
API_HOST=127.0.0.1
API_PORT=8000
DEBUG=True

# LLM Provider Configuration
LLM_PROVIDER=groq
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# RAG Configurations
EMBEDDING_MODEL=all-MiniLM-L6-v2
SIMILARITY_THRESHOLD=0.15
TOP_K_CONTEXT=3

# Scheduler Configurations
CRAWL_INTERVAL_HOURS=24
